#!/usr/bin/env bash
# Re-exec under bash if invoked by sh (husky v9 uses sh -e)
if [ -z "$BASH_VERSION" ]; then
  exec bash "$0" "$@"
fi
# Run independent stages in parallel; fail fast on any non-zero exit.
# Each stage's stdout/stderr is buffered to a tempfile and replayed in order
# so logs stay readable.
set -o pipefail
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$HOOK_DIR/../scripts/ensure-tools.sh"
require_tool osv-scanner "dependency vulnerability scanning"

TMPDIR_HOOK=$(mktemp -d -t wooly-prepush-XXXXXX)
trap 'rm -rf "$TMPDIR_HOOK"' EXIT

run_bg() {
  local name="$1"; shift
  ( "$@" >"$TMPDIR_HOOK/$name.log" 2>&1; echo $? >"$TMPDIR_HOOK/$name.exit" ) &
  eval "PID_$name=$!"
}

wait_stage() {
  local name="$1" pid_var="PID_$1" pid status
  pid=${!pid_var}
  wait "$pid" 2>/dev/null || true
  status=$(cat "$TMPDIR_HOOK/$name.exit" 2>/dev/null || echo 1)
  echo "━━━ $name (exit=$status) ━━━"
  cat "$TMPDIR_HOOK/$name.log"
  if [ "$status" -ne 0 ]; then
    echo "❌ pre-push stage '$name' failed" >&2
    exit "$status"
  fi
}

# Launch all eight stages concurrently.
run_bg build        bun run build
run_bg unit_cov     bun run test:unit:coverage
run_bg api_test     bun run test:api
run_bg worker_test  bun run test:worker
run_bg worker_tc    bun run typecheck:worker
run_bg lint         bun run lint
run_bg osv_root     osv-scanner scan --lockfile=bun.lock --config=osv-scanner.toml
run_bg osv_worker   osv-scanner scan --lockfile=worker/bun.lock

# Wait in declaration order so logs print deterministically.
wait_stage build
wait_stage unit_cov
wait_stage api_test
wait_stage worker_test
wait_stage worker_tc
wait_stage lint
wait_stage osv_root
wait_stage osv_worker
