# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# NextAuth.js (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Base URL for your application (used for callbacks)
# Leave empty to auto-detect from request headers (recommended)
# Only set this if auto-detection doesn't work for your setup
# Examples:
#   - http://localhost:7014 (local development)
#   - https://wooly.example.com (production)
AUTH_URL=

# Comma-separated list of allowed Google emails
AUTH_ALLOWED_EMAILS=

# Reverse Proxy Configuration (Development Only)
# Set to "true" if using HTTPS reverse proxy in development
# This enables secure cookies which are required for HTTPS
# Not needed in production (NODE_ENV=production auto-enables this)
USE_SECURE_COOKIES=false

# Wooly Worker — Cloudflare D1 API proxy (server-side only)
# These env vars configure the Next.js server → Worker connection.
# Never exposed to the browser.
#
# Two modes:
#
# 1. REMOTE worker (recommended for day-to-day dev — no local wrangler needed):
#    WOOLY_WORKER_URL=https://wooly.worker.hexly.ai
#    WOOLY_API_KEY=<the API_KEY secret set on the Worker>
#    WOOLY_ALLOW_RESET=false
#    Then `bun run dev` (script detects remote URL and skips local wrangler).
#
# 2. LOCAL worker (fully offline stack):
#    WOOLY_WORKER_URL=http://localhost:8787
#    WOOLY_API_KEY=dev-local-key   # matches the .dev.vars dev key the script writes
#    WOOLY_ALLOW_RESET=true
#    `bun run dev` boots both wrangler (8787) and Next.js (7014).
#
# WOOLY_API_KEY: must match the API_KEY secret on the target Worker:
#   - prod: `cd worker && wrangler secret put API_KEY` (one-time)
#   - local: auto-set to "dev-local-key" by scripts/dev.sh
WOOLY_WORKER_URL=https://wooly.worker.hexly.ai
WOOLY_API_KEY=
# Reset gate — "true" enables POST /api/data/reset.
# Keep false in production. Only enable for local dev or E2E testing.
# Also requires ALLOW_RESET=true on the Worker side (.dev.vars for local).
WOOLY_ALLOW_RESET=false
