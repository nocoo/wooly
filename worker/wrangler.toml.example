# Wooly Worker — Cloudflare Worker configuration
# Copy to wrangler.toml and fill in your D1 database details.

name = "wooly-worker"
main = "src/index.ts"
compatibility_date = "2025-04-01"

# ─── D1 Database Binding ────────────────────────────────────────────────────
[[d1_databases]]
binding = "DB"
database_name = "<YOUR_D1_DATABASE_NAME>"
database_id = "<YOUR_D1_DATABASE_ID>"
migrations_dir = "migrations"

# ─── Plain Variables ────────────────────────────────────────────────────────
# ALLOW_RESET defaults to off in production. Enable in .dev.vars for local dev.
[vars]
ALLOW_RESET = "false"

# ─── Secrets (set via `wrangler secret put`) ────────────────────────────────
# API_KEY — shared key for x-api-key header authentication
#           Must match WOOLY_API_KEY on the Docker/Next.js site.
