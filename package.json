{
  "name": "wooly",
  "private": true,
  "overrides": {
    "postcss": "^8.5.15",
    "esbuild": "^0.28.1",
    "vite": "^7.3.5",
    "@babel/core": "^7.29.6",
    "js-yaml": "^4.2.0"
  },
  "version": "0.0.6",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:site": "next dev --turbopack --port 7014",
    "dev:worker": "cd worker && bun run dev",
    "build": "next build",
    "start": "next start --port 7014",
    "lint": "eslint --max-warnings=0 .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit:coverage": "vitest run --coverage",
    "test:api": "vitest run --config vitest.api.config.ts",
    "test:e2e:bdd": "bunx playwright test",
    "test:worker": "cd worker && bun run test",
    "typecheck:worker": "cd worker && bun x tsc --noEmit",
    "release": "bun scripts/release.ts",
    "prepare": "husky",
    "typecheck": "bash scripts/typecheck.sh"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "1.1.16",
    "@radix-ui/react-avatar": "1.1.12",
    "@radix-ui/react-collapsible": "1.1.13",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-select": "2.3.0",
    "@radix-ui/react-separator": "1.1.9",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-tooltip": "1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.30",
    "postcss": "^8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.8.1",
    "sonner": "2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  }
}
