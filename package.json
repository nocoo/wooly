{
  "name": "wooly",
  "private": true,
  "overrides": {
    "postcss": "^8.5.21",
    "esbuild": "^0.28.1",
    "vite": "^7.3.5",
    "@babel/core": "^7.29.6",
    "js-yaml": "^4.2.0",
    "undici": "^7.28.0"
  },
  "version": "0.0.7",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:site": "next dev --turbopack --port 7014",
    "dev:worker": "cd worker && bun run dev",
    "build": "next build",
    "start": "next start --port 7014",
    "lint": "eslint --max-warnings=0 .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit:coverage": "vitest run --coverage",
    "test:api": "vitest run --config vitest.api.config.ts",
    "test:e2e:bdd": "bunx playwright test",
    "test:worker": "cd worker && bun run test",
    "typecheck:worker": "cd worker && bun x tsc --noEmit",
    "release": "bun scripts/release.ts",
    "prepare": "husky",
    "typecheck": "bash scripts/typecheck.sh"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "1.1.20",
    "@radix-ui/react-avatar": "1.2.3",
    "@radix-ui/react-collapsible": "1.1.17",
    "@radix-ui/react-dialog": "1.1.20",
    "@radix-ui/react-dropdown-menu": "2.1.21",
    "@radix-ui/react-label": "2.1.12",
    "@radix-ui/react-select": "2.3.4",
    "@radix-ui/react-separator": "1.1.12",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-tooltip": "1.2.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "1.25.0",
    "next": "16.2.11",
    "next-auth": "^5.0.0-beta.30",
    "postcss": "^8.5.21",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "recharts": "3.10.0",
    "sonner": "2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "5.17.3",
    "@next/eslint-plugin-next": "16.2.11",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "4.1.10",
    "brace-expansion": "1.1.16",
    "eslint": "10.7.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  }
}
